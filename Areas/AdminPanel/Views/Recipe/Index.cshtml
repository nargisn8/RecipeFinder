@using RecipeProject.Areas.AdminPanel.ViewModels.Recipe
@model List<GetRecipeVM>

@{
    ViewData["Title"] = "Recipes";
}

<h2 style="color:black">Recipes</h2>
<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px; gap: 10px; flex-wrap: wrap;">
    <div style="display:flex; gap:10px; align-items:center;">
        <a href="/AdminPanel/Recipe/Create" class="btn btn-peach">Create</a>

        <form asp-action="Index" method="get" class="d-flex">
            <div class="input-group" style="width: 250px;">
                <input type="text" name="searchString" value="@ViewBag.CurrentSearch"
                       class="form-control" placeholder="Search recipe..."
                       style="border-radius: 20px 0 0 20px; border: 1px solid #ddd;">
                <button type="submit" class="btn btn-peach" style="border-radius: 0 20px 20px 0;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </button>
            </div>
            @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch))
            {
                <a asp-action="Index" class="btn btn-link text-secondary">Reset</a>
            }
        </form>
    </div>

    <a href="/AdminPanel/Ingredient/Index" class="btn btn-peach" style="background:#fff; border-radius:20px; padding:8px 20px; border: 1px solid #ddd;">
        <i class="fa-solid fa-leaf"></i> Ingredients
    </a>
</div>

<div class="white-container">
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Diet Type</th>
                <th>Cuisine</th>
                <th>Details</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.DietType</td>
                    <td>@item.Cuisine</td>
                    <td>
                        <a href="/AdminPanel/Recipe/Detail/@item.Id">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/AdminPanel/Recipe/Update/@item.Id">
                            <i class="fa-solid fa-pen"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/AdminPanel/Recipe/Delete/@item.Id">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a href="/AdminPanel/Dashboard/Index" class="btn btn-light">
        Back
    </a>
</div>