@using RecipeProject.Areas.AdminPanel.ViewModels.Recipe
@model List<GetRecipeVM>

@{
    ViewData["Title"] = "Recipes";
}

<h2 style="color:black">Recipes</h2>

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:15px;">
    <a href="/AdminPanel/Recipe/Create" class="btn btn-peach">Create</a>
    <a href="/AdminPanel/Ingredient/Index" class="btn btn-peach" style="background:#fff; border-radius:20px; padding:8px 20px;">
        <i class="fa-solid fa-leaf"></i> Ingredients
    </a>
</div>

<div class="white-container">
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Diet Type</th>
                <th>Cuisine</th>
                <th>Details</th>
                <th>Update</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.DietType</td>
                    <td>@item.Cuisine</td>
                    <td>
                        <a href="/AdminPanel/Recipe/Detail/@item.Id">
                            <i class="fa-solid fa-eye"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/AdminPanel/Recipe/Update/@item.Id">
                            <i class="fa-solid fa-pen"></i>
                        </a>
                    </td>
                    <td>
                        <a href="/AdminPanel/Recipe/Delete/@item.Id">
                            <i class="fa-solid fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a href="/AdminPanel/Dashboard/Index" class="btn btn-light">
        Back
    </a>
</div>