<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <!-- Fonts + Bootstrap -->
    <link href="https://fonts.googleapis.com/css2?family=Pacifico&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" />
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <!-- Admin styles -->
    <link rel="stylesheet" href="/admin/css/admin.css" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <header class="landing-header py-4" style="display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; position: relative; width: 100%;">

        <div></div>

        <div class="text-center">
            <h2 class="landing-title m-0" style="color: black !important; font-weight: bold; font-size: 32px; line-height: 1.2;">Admin</h2>
            <p class="landing-subtitle m-0" style="color: #000; font-size: 14px;">Delicious</p>
        </div>

        <div style="display: flex; justify-content: flex-end; padding-right: 40px;">
            <a class="landing-home" href="/" style="color: black !important; font-weight: 600; text-decoration: none; font-size: 18px; display: flex; align-items: center;">
                <i class="fa-solid fa-house" style="margin-right: 8px;"></i> Home
            </a>
        </div>

    </header>

    @RenderSection("Hero", required: false)

    <div class="page-wrapper page-content">
        <div class="container my-5">
            @RenderBody()
        </div>
    </div>

    <footer class="bg-dark text-white text-center py-4">
        <p class="mb-0">&copy; 2026 DELICIOUS</p>
    </footer>

    <!-- Scripts burada olmalıdır -->
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.16.1/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>