@using RecipeProject.Areas.AdminPanel.ViewModels.Ingredient
@model UpdateIngredientVM

@{
    ViewData["Title"] = "Update Ingredient";
}

<h1>Update Ingredient</h1>
<hr />

<form asp-area="AdminPanel" asp-controller="Ingredient" asp-action="Update" method="post">
    @Html.AntiForgeryToken()

    <input type="hidden" name="Id" value="@Model.Id" />

    <div class="form-group">
        <label for="Name">Name</label>
        <input type="text" name="Name" id="Name" class="form-control" value="@Model.Name" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-peach">
        Update
    </button>
</form>

<a href="/AdminPanel/Ingredient/Index" class="btn btn-light">
    Back to list
</a>