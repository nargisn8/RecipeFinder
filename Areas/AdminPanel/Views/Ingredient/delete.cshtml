@using RecipeProject.Models
@model Ingredient

@{
    ViewData["Title"] = "Delete Ingredient";
}

<h1>Delete Ingredient</h1>
<hr />

<h3>Are you sure you want to delete this ingredient?</h3>

<div>
    <dl class="row">
        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>
    </dl>
</div>

<form action="/AdminPanel/Ingredient/Delete/@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <button type="submit" class="btn btn-danger">Delete</button>
    <a href="/AdminPanel/Ingredient/Index" class="btn btn-light">Cancel</a>
</form>
