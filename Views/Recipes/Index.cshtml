@using RecipeProject.ViewModels
@model RecipesVM

@{
    /* Kart sayına görə sütun ölçüsünü təyin et */
    var hasFilter = !string.IsNullOrWhiteSpace(Model.Search)
                 || !string.IsNullOrWhiteSpace(Model.Cuisine)
                 || !string.IsNullOrWhiteSpace(Model.DietType)
                 || Model.IngredientId.HasValue;

    var recipeCount = Model.Recipes.Count;

    /* Filter aktiv + az nəticə varsa böyük kartlar, yoxsa standart 3-lü grid */
    string colClass = hasFilter && recipeCount <= 2
        ? "col-12 col-sm-6"
        : "col-12 col-sm-6 col-lg-4";
}

<!-- ##### Breadcumb Area Start ##### -->
<div class="breadcumb-area bg-img bg-overlay" style="background-image: url(img/bg-img/breadcumb3.jpg);">
    <div class="container h-100">
        <div class="row h-100 align-items-center">
            <div class="col-12">
                <div class="breadcumb-text text-center">
                    <h2>Recipe</h2>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ##### Breadcumb Area End ##### -->

<div class="receipe-post-area section-padding-80">

    <!-- Receipe Post Search -->
    <div class="receipe-post-search mb-80">
        <div class="container">
            <form action="#" method="post">
                <div class="row">
                    <!-- Replace the Cuisines dropdown with this -->
                    <div class="col-12 col-lg-3">
                        <select name="cuisine" id="select1">
                            <option value="">All Cuisines</option>
                            @foreach (var cuisine in Model.Cuisines)
                            {
                                <option value="@cuisine">@cuisine</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-lg-3">
                        <select name="diet" id="select2">
                            <option value="">All Diet Types</option>
                            @foreach (var diet in Model.DietTypes)
                            {
                                <option value="@diet">@diet</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 col-lg-3">
                        <input type="search" name="search" placeholder="Search Receipies">
                    </div>
                    <div class="col-12 col-lg-3 text-right">
                        <button type="submit" class="btn delicious-btn">Search</button>
                    </div>
                </div>
            </form>
        </div>
    </div>



    <!-- Receipe Content Area -->
    <div class="receipe-content-area">
        <div class="container">


            <div class="row">
                <!-- ##### Best Receipe Area Start ##### -->
                <section class="best-receipe-area">
                    <div class="container">
                        <div class="row">
                            <!-- Single Best Receipe Area -->
                            @foreach (var recipe in Model.Recipes)
                            {
                                <div class="@colClass">
                                    <div class="single-best-receipe-area mb-30">

                                        <img src="@recipe.ImageUrl" alt="@recipe.Name">

                                        <div class="receipe-content">
                                            <h5 class="mb-1">@recipe.Name</h5>
                                            <small class="text-muted">@recipe.Cuisine</small>
                                        </div>

                                        <!-- Hover detail card -->
                                        <div class="hover-card">
                                            <div class="hover-card-top">
                                                <img class="hover-img" src="@recipe.ImageUrl" alt="@recipe.Name" />

                                                <div style="min-width:0;">
                                                    <p class="hover-title">@recipe.Name</p>

                                                    <div class="hover-meta">
                                                        @if (!string.IsNullOrWhiteSpace(recipe.Cuisine))
                                                        {
                                                            <span class="pill">@recipe.Cuisine</span>
                                                        }
                                                        @if (!string.IsNullOrWhiteSpace(recipe.DietType) && recipe.DietType != "None")
                                                        {
                                                            <span class="pill">@recipe.DietType</span>
                                                        }
                                                    </div>
                                                </div>
                                            </div>

                                            <p class="hover-desc">
                                                @(string.IsNullOrWhiteSpace(recipe.Description) ? "No description yet." : recipe.Description)
                                            </p>

                                            <div class="ing-title">Ingredients</div>
                                            <ul class="ing-list">
                                                @if (recipe.RecipeIngredients != null && recipe.RecipeIngredients.Any())
                                                {
                                                    foreach (var ri in recipe.RecipeIngredients)
                                                    {
                                                        var ingName = ri.Ingredient?.Name ?? "Unknown";
                                                        var qty = string.IsNullOrWhiteSpace(ri.Quantity) ? "" : $" — {ri.Quantity}";
                                                        <li>@ingName@qty</li>
                                                    }
                                                }
                                                else
                                                {
                                                    <li>No ingredients yet.</li>
                                                }
                                            </ul>
                                        </div>

                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </section>
                <!-- ##### Best Receipe Area End ##### -->
            </div>

            <!-- Receipe Slider -->
            <div class="container">
                <div class="row">
                    <div class="col-12">
                        <div class="receipe-slider owl-carousel">
                            <img src="img/bg-img/bg5.jpg" alt="">
                            <img src="img/bg-img/bg5.jpg" alt="">
                            <img src="img/bg-img/bg5.jpg" alt="">
                        </div>
                    </div>
                </div>
            </div>
            <br />
            <div class="row">
                <div class="col-12">
                    <div class="section-heading text-left">
                        <h3>Leave a comment</h3>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-12">
                    <div class="contact-form-area">
                        <form action="#" method="post">
                            <div class="row">
                                <div class="col-12 col-lg-6">
                                    <input type="text" class="form-control" id="name" placeholder="Name">
                                </div>
                                <div class="col-12 col-lg-6">
                                    <input type="email" class="form-control" id="email" placeholder="E-mail">
                                </div>
                                <div class="col-12">
                                    <input type="text" class="form-control" id="subject" placeholder="Subject">
                                </div>
                                <div class="col-12">
                                    <textarea name="message" class="form-control" id="message" cols="30" rows="10" placeholder="Message"></textarea>
                                </div>
                                <div class="col-12">
                                    <button class="btn delicious-btn mt-30" type="submit">Post Comments</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

