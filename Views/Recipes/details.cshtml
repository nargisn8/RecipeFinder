@model RecipeProject.Models.Recipe

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" alt="@Model.Name">
        </div>

        <div class="col-md-6">
            <h1 class="display-4">@Model.Name</h1>
            <p class="text-muted"><strong>Cuisine:</strong> @Model.Cuisine | <strong>Diet:</strong> @Model.DietType</p>
            <hr />

            <h3 class="text-primary"><i class="fa-solid fa-align-left"></i> Description</h3>
            <p class="mb-4">@Model.Description</p>

            <h3 class="text-success"><i class="fa-solid fa-basket-shopping"></i> Ingredients</h3>
            <div class="bg-light p-3 rounded border">
                @if (Model.RecipeIngredients != null && Model.RecipeIngredients.Any())
                {
                    <ul class="list-unstyled">
                        @foreach (var item in Model.RecipeIngredients)
                        {
                            <li class="py-2 border-bottom">
                                <i class="fa-solid fa-circle-check text-success me-2"></i>
                                <span>@item.Ingredient?.Name</span>
                                <span class="float-right font-weight-bold">@item.Quantity</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">No ingredients listed for this recipe.</p>
                }
            </div>

            <div class="mt-4">
                <a asp-controller="Wishlist" asp-action="Index" class="btn btn-outline-danger">
                    <i class="fa-solid fa-heart"></i> Back to Wishlist
                </a>
                <a asp-controller="Recipes" asp-action="Index" class="btn btn-secondary ml-2">
                    Browse Recipes
                </a>
            </div>
        </div>
    </div>
</div>