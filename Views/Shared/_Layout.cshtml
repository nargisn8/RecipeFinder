@using Microsoft.AspNetCore.Identity
@using RecipeProject.Models
@using Microsoft.EntityFrameworkCore

@inject RecipeProject.Data.AppDbContext _context
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@{
    var userName = User.Identity.Name;
    var initialCount = 0;
    if (!string.IsNullOrEmpty(userName))
    {
        var wishlist = _context.Wishlists
            .Include(w => w.Recipes)
            .FirstOrDefault(w => w.UserId == userName);
        initialCount = wishlist?.Recipes?.Count ?? 0;
    }
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="description" content="">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- The above 4 meta tags *must* come first in the head; any other head content must come *after* these tags -->
    <!-- Title -->
    <title>Delicious - Food Blog Template | Home</title>

    <!-- Favicon -->
    <link rel="icon" href="~/img/core-img/favicon.ico">

    <!-- Core Stylesheet -->
    <link rel="stylesheet" href="~/style.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
</head>
<body>
    <!-- Preloader -->
    <div id="preloader">
        <i class="circle-preloader"></i>
        <img src="~/img/core-img/salad.png" alt="">
    </div>

    <!-- Search Wrapper -->
    <div class="search-wrapper">
        <!-- Close Btn -->
        <div class="close-btn"><i class="fa fa-times" aria-hidden="true"></i></div>

        <div class="container">
            <div class="row">
                <div class="col-12">
                    <form action="/Recipes" method="get" id="recipeSearchForm">
                        <input type="text" name="search" placeholder="Search recipes..." id="search-bar">
                        <button type="submit"><i class="fa fa-search"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- ##### Header Area Start ##### -->
    <header class="header-area">

        <!-- Top Header Area -->
        <div class="top-header-area">
            <div class="container h-100">
                <div class="row h-100 align-items-center justify-content-between">
                    <!-- Breaking News -->
                    <div class="col-12 col-sm-6">
                        <div class="breaking-news">
                            <div id="breakingNewsTicker" class="ticker">
                                <ul>
                                    <li><a href="#">Hello World!</a></li>
                                    <li><a href="#">Welcome to Colorlib Family.</a></li>
                                    <li><a href="#">Hello Delicious!</a></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-sm-6">
                        <div class="top-social-info text-right">
                            <a href="#"><i class="fa-brands fa-pinterest" aria-hidden="true"></i></a>

                            <a href="#"><i class="fa-brands fa-facebook" aria-hidden="true"></i></a>

                            <a href="#"><i class="fa-brands fa-x-twitter" aria-hidden="true"></i></a>

                            <a href="#"><i class="fa-brands fa-dribbble" aria-hidden="true"></i></a>

                            <a href="#"><i class="fa-brands fa-behance" aria-hidden="true"></i></a>

                            <a href="#"><i class="fa-brands fa-linkedin" aria-hidden="true"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Navbar Area -->
        <div class="delicious-main-menu">
            <div class="classy-nav-container breakpoint-off">
                <div class="container">
                    <!-- Menu -->
                    <nav class="classy-navbar justify-content-between" id="deliciousNav">

                        <!-- Logo -->
                        <a class="nav-brand" href="index.html"><img src="~/img/core-img/logo.png" alt=""></a>

                        <!-- Navbar Toggler -->
                        <div class="classy-navbar-toggler">
                            <span class="navbarToggler"><span></span><span></span><span></span></span>
                        </div>

                        <!-- Menu -->
                        <div class="classy-menu">

                            <!-- close btn -->
                            <div class="classycloseIcon">
                                <div class="cross-wrap"><span class="top"></span><span class="bottom"></span></div>
                            </div>
                            <!-- Nav Start -->
                            <div class="classynav">
                                <ul>
                                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                                    <li>
                                    </li>
                                    <li><a asp-controller="Recipes" asp-action="Index">Recipes</a></li>
                                 
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li><a asp-area="AdminPanel" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                                    }

                                  

                                    <!-- Account dropdown -->
                                    <li>
                                        <a href="javascript:void(0)" style="font-size: 22px; color: #333; display: inline-block; padding: 5px;">
                                            <i class="fa-solid fa-circle-user"></i>
                                        </a>
                                        <ul class="dropdown">
                                            @if (SignInManager.IsSignedIn(User))
                                            {
                                                <li>
                                                    <a href="#" style="pointer-events:none; opacity:.6;">
                                                        <i class="fa-solid fa-user" aria-hidden="true"></i> @User.Identity!.Name
                                                    </a>
                                                </li>
                                                <li>
                                                    <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <button type="submit" style="background:none; border:none; padding:0 18px; cursor:pointer; font-weight:600; font-size:14px; color:#797979; width:100%; text-align:left; line-height:40px;">
                                                            <i class="fa-solid fa-right-from-bracket" aria-hidden="true"></i> Logout
                                                        </button>
                                                    </form>
                                                </li>
                                            }
                                            else
                                            {
                                                <li>
                                                    <a asp-controller="Account" asp-action="Login">
                                                        <i class="fa-solid fa-right-to-bracket" aria-hidden="true"></i> Login
                                                    </a>
                                                </li>
                                                <li>
                                                    <a asp-controller="Account" asp-action="Register">
                                                        <i class="fa-solid fa-user-plus" aria-hidden="true"></i> Register
                                                    </a>
                                                </li>
                                            }
                                        </ul>
                                    </li>
                                    <li class="nav-item">
                                        <a class="nav-link wishlist-link" asp-controller="Wishlist" asp-action="Index" style="position: relative; display: inline-block;">
                                            <i class="fa-regular fa-heart" style="font-size: 1.2rem;"></i>
                                            <span id="wishlist-count" class="wishlist-badge">@initialCount</span>
                                        </a>
                                    </li>
                                </ul>

                                <div class="search-btn">
                                    <i class="fa fa-search" aria-hidden="true"></i>
                                </div>

                                <div class="search-wrapper">
                                    <div class="close-btn"><i class="fa fa-times" aria-hidden="true"></i></div>

                                    <div class="container">
                                        <div class="row">
                                            <div class="col-12">
                                                <form asp-controller="Recipes" asp-action="Index" method="get" id="recipeSearchForm">
                                                    <input type="search" name="search" placeholder="Resept axtar..." id="search-bar">
                                                    <button type="submit"><i class="fa fa-search"></i></button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                            </div>
                            <!-- Nav End -->
                        </div>
                    </nav>
                </div>
            </div>
        </div>
    </header>
    <!-- ##### Header Area End ##### -->
    @RenderBody()

    <!-- ##### Footer Area Start ##### -->
    <footer class="footer-area">
        <div class="container h-100">
            <div class="row h-100">
                <div class="col-12 h-100 d-flex flex-wrap align-items-center justify-content-between">
                    <div class="footer-social-info text-right">
                        <a href="#"><i class="fa-brands fa-pinterest" aria-hidden="true"></i></a>
                        <a href="#"><i class="fa-brands fa-facebook" aria-hidden="true"></i></a>
                        <a href="#"><i class="fa-brands fa-x-twitter" aria-hidden="true"></i></a> <a href="#"><i class="fa-brands fa-dribbble" aria-hidden="true"></i></a>
                        <a href="#"><i class="fa-brands fa-behance" aria-hidden="true"></i></a>
                        <a href="#"><i class="fa-brands fa-linkedin" aria-hidden="true"></i></a>
                    </div>
                    <!-- Footer Logo -->
                    <div class="footer-logo">
                        <a href="index.html"><img src="~/img/core-img/logo.png" alt=""></a>
                    </div>
                    <!-- Copywrite -->
                    <p>
                        <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
                        Copyright &copy;<script>document.write(new Date().getFullYear());</script> All rights reserved</a>
                        <!-- Link back to Colorlib can't be removed. Template is licensed under CC BY 3.0. -->
                    </p>
                </div>
            </div>
        </div>
    </footer>
    <!-- ##### Footer Area Start ##### -->
    <!-- ##### All Javascript Files ##### -->
    <!-- jQuery-2.2.4 js -->
    <script src="~/js/jquery/jquery-2.2.4.min.js"></script>
    <!-- Popper js -->
    <script src="~/js/bootstrap/popper.min.js"></script>
    <!-- Bootstrap js -->
    <script src="~/js/bootstrap/bootstrap.min.js"></script>
    <!-- All Plugins js -->
    <script src="~/js/plugins/plugins.js"></script>
    <!-- Active js -->
    <script src="/js/active.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var searchForm = document.getElementById('recipeSearchForm');
            var searchInput = searchForm.querySelector('input[name="search"]');
            searchForm.onsubmit = function (e) {
                e.preventDefault();
                var query = searchInput.value;
                if (query.trim() !== "") {
                    window.location.href = '/Recipes?search=' + encodeURIComponent(query);
                }
            };
        });
    </script>

    <script>
        $(document).ready(function () {
            $('.search-btn').on('click', function () {
                $('.search-wrapper').addClass('search-wrapper-open');
            });

            $('.close-btn').on('click', function () {
                $('.search-wrapper').removeClass('search-wrapper-open');
            });
        });
    </script>

    <script src="~/js/site.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
