@model RecipeProject.Models.Wishlist

@{
    ViewData["Title"] = "My Wishlist";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fa-solid fa-heart text-danger"></i> My Wishlist</h2>
        <a asp-controller="Recipes" asp-action="Index" class="btn btn-outline-secondary">
            <i class="fa-solid fa-arrow-left"></i> Back to Recipes
        </a>
    </div>

    <hr />

    @if (Model.Recipes != null && Model.Recipes.Any())
    {
        <div class="row" id="wishlist-container">
            @foreach (var recipe in Model.Recipes)
            {
                <div class="col-lg-4 col-md-6 mb-4 recipe-item" id="recipe-@recipe.Id">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="position-relative">
                            <img src="@recipe.ImageUrl" class="card-img-top" alt="@recipe.Name" style="height: 200px; object-fit: cover; border-radius: 10px 10px 0 0;">
                            <button class="btn btn-light position-absolute border-0 shadow-sm remove-item"
                                    data-id="@recipe.Id"
                                    style="top: 10px; right: 10px; border-radius: 50%; width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-trash-can text-danger"></i>
                            </button>
                        </div>
                        <div class="card-body">
                            <h5 class="card-title font-weight-bold">@recipe.Name</h5>
                            <p class="card-text text-muted small">Added to your personal collection.</p>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            <a asp-controller="Recipes" asp-action="Details" asp-route-id="@recipe.Id" class="btn btn-dark btn-block">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="fa-regular fa-face-frown mb-3" style="font-size: 4rem; color: #ccc;"></i>
            <h4>Your wishlist is empty</h4>
            <p class="text-muted">Explore our recipes and save your favorites!</p>
            <a asp-controller="Recipes" asp-action="Index" class="btn btn-primary mt-3">Browse Recipes</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $(document).on('click', '.remove-item', function (e) {
                e.preventDefault();

                var btn = $(this);
                var recipeId = btn.data('id');
                var card = $('#recipe-' + recipeId);

                if (confirm("Are you sure you want to delete this recipe?")) {
                    $.ajax({
                        url: '/Wishlist/RemoveRecipe',
                        type: 'POST',
                        data: { recipeId: recipeId },
                        success: function (response) {
                            if (response.success) {
                                card.fadeOut(500, function() {
                                    $(this).remove();

                                    if ($('.recipe-item').length === 0) {
                                        location.reload();
                                    }
                                });

                                var countEl = $('#wishlist-count');
                                if(countEl.length > 0) {
                                    var count = parseInt(countEl.text()) || 0;
                                    if (count > 0) {
                                        countEl.text(count - 1);
                                    }
                                }
                            } else {
                                alert("Error: Could not remove from list.");
                            }
                        },
                        error: function() {
                            alert("Server connection lost.");
                        }
                    });
                }
            });
        });
    </script>
}

